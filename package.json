{
  "name": "binaclaw",
  "version": "0.1.6",
  "description": "A Binance-focused CLI AI agent inspired by Dexter and Binance Skills.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "binaclaw": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "README.zh-CN.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --out-dir dist --clean --splitting --sourcemap",
    "chat": "node dist/index.js chat",
    "dev:chat": "node --experimental-strip-types src/index.ts chat",
    "dev:onboard": "node --experimental-strip-types src/index.ts onboard",
    "dev:gateway": "node --experimental-strip-types src/index.ts gateway",
    "dev:telegram": "node --experimental-strip-types src/index.ts telegram",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build && node dist/index.js doctor",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "grammy": "^1.41.1",
    "openai": "^6.29.0",
    "ws": "^8.19.0"
  }
}
