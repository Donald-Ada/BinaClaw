{
  "name": "binaclaw",
  "version": "0.1.0",
  "description": "A Binance-focused CLI AI agent inspired by Dexter and Binance Skills.",
  "type": "module",
  "bin": {
    "binaclaw": "./src/index.ts"
  },
  "files": [
    "src",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=25.0.0"
  },
