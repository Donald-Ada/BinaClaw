    "check": "node --test tests/*.test.ts && node src/index.ts doctor"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "grammy": "^1.41.1",
    "openai": "^6.29.0",
    "ws": "^8.19.0"
  }
}
